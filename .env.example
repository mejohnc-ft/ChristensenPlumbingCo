# Christensen Plumbing Co. - Environment Variables
# Copy this file to .env.local and fill in your values

# ============================================
# CLERK AUTHENTICATION (REQUIRED)
# Get from: https://clerk.com/dashboard → Your App → API Keys
# ============================================
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================
# SUPABASE DATABASE & STORAGE (REQUIRED)
# Get from: https://supabase.com/dashboard → Project → Settings → API
# ============================================
VITE_SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxx
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxx

# ============================================
# GOOGLE MAPS (REQUIRED)
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
# ============================================
VITE_GOOGLE_MAPS_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================
# SENTRY ERROR TRACKING (OPTIONAL - can add later)
# Get from: https://sentry.io → Project → Settings → Client Keys (DSN)
# ============================================
VITE_SENTRY_DSN=https://xxxxx@xxxxx.ingest.sentry.io/xxxxx

# ============================================
# SITE CONFIGURATION
# ============================================
VITE_SITE_URL=https://christensenplumbing.com
VITE_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
